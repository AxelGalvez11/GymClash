# GymClash Video Analysis Service
# Copy this to .env and fill in values

# App settings
GYMCLASH_DEBUG=false
GYMCLASH_APP_VERSION=1.0.0

# MediaPipe
GYMCLASH_MEDIAPIPE_MODEL_PATH=pose_landmarker_heavy.task
GYMCLASH_NUM_POSES=1
GYMCLASH_MIN_DETECTION_CONFIDENCE=0.5
GYMCLASH_MIN_PRESENCE_CONFIDENCE=0.5
GYMCLASH_MIN_TRACKING_CONFIDENCE=0.5

# Video processing
GYMCLASH_FRAME_SAMPLE_RATE=10
GYMCLASH_MAX_VIDEO_DURATION_SECONDS=600
GYMCLASH_MAX_VIDEO_SIZE_MB=200

# Analysis
GYMCLASH_SMOOTHING_WINDOW=5
GYMCLASH_MIN_REP_AMPLITUDE_DEGREES=30
GYMCLASH_MIN_REP_CONFIDENCE=0.3
GYMCLASH_ENABLE_DEBUG_OUTPUT=false

# Supabase (for persistence — optional for local dev)
GYMCLASH_SUPABASE_URL=
GYMCLASH_SUPABASE_SERVICE_KEY=
GYMCLASH_SUPABASE_STORAGE_BUCKET=workout-videos

# Server
GYMCLASH_HOST=0.0.0.0
GYMCLASH_PORT=8000
